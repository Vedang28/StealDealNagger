# ─── Core ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/staledealnagger

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Auth ──────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ─── Encryption (for OAuth tokens at rest) ─────────
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ─── Frontend URL ──────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Email (SMTP) ─────────────────────────────────
# Leave EMAIL_HOST empty to use mock transport (logs only)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@staledealnagger.com

# ─── HubSpot OAuth (optional) ─────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:5173/integrations

# ─── Slack (optional) ──────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
